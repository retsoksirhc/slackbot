{
    "compilerOptions": {
        "target": "ES2020",
        "module": "commonjs",
        "moduleResolution": "node",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "declaration": true,
        "outDir": "./dist",
        "removeComments": true,
        "preserveConstEnums": true,
        "sourceMap": true
    },
    "include": ["*.ts"],
    "exclude": ["node_modules", "dist", "example"]
}
